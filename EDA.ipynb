   },
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import missingno as msno\n",
    "from lifelines import KaplanMeierFitter\n",
    "from lifelines.plotting import add_at_risk_counts\n",
    "from lifelines import CoxPHFitter\n",
    "from lifelines.statistics import logrank_test\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "pd.set_option('display.max_rows', None)\n",
    "\n",
    "%matplotlib inline"
   ],
   "outputs": [],
   "execution_count": 28
  },
  {
   "cell_type": "markdown",
   "id": "28a1ea29",
   "metadata": {},
   "source": [
    "## Read the csv and standardize column values on the overall dataframe"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "115bc3b6",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-04-08T19:46:21.124772Z",
     "start_time": "2026-04-08T19:46:20.840327Z"
    }
   },
   "source": [
    "df = pd.read_csv(\"METABRIC_RNA_Mutation.csv\", \n",
    "    dtype={\n",
    "        \"rasgef1b_mut\": str,\n",
    "        \"hras_mut\": str,\n",
    "        \"smarcb1_mut\": str,\n",
    "        \"siah1_mut\": str\n",
    "    })\n",
    "\n",
    "# Strip whitespace and standardize capitalization\n",
    "string_cols = df.select_dtypes(include=['object', 'string']).columns.tolist()\n",
    "for col in string_cols:\n",
    "    df[col] = df[col].str.strip().str.title()  # title case, removes extra spaces\n",
    "\n",
    "# Map inconclusive values to np.nan\n",
    "df['cancer_type_detailed'] = df['cancer_type_detailed'].replace({'Breast': np.nan})\n",
    "df['pam50_+_claudin-low_subtype'] = df['pam50_+_claudin-low_subtype'].replace({'Nc': np.nan})\n",
    "df['her2_status_measured_by_snp6'] = df['her2_status_measured_by_snp6'].replace({'Undef': np.nan})"
   ],
   "outputs": [],
   "execution_count": 29
  },
  {
   "cell_type": "markdown",
   "id": "82737eb4",
   "metadata": {},
   "source": [
    "## Seperate the DataFrame"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c28f0119",
   "metadata": {},
   "source": [
    "We have three different types of data in this one dataset: clinical attributes (cols: 1-31), gene expressions (cols: ), and gene mutations (cols appended with *_mut). We are going to seperate these into three different DataFrames."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "1f52e35f",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-04-08T19:46:27.870168Z",
     "start_time": "2026-04-08T19:46:27.817176Z"
    }
   },
   "source": [
    "# Clinical attributes\n",
    "clinical_cols = df.columns[:31]\n",
    "clinical_df = df[clinical_cols].copy()\n",
    "\n",
    "print(\"Clinical attributes shape:\", clinical_df.shape)\n",
    "\n",
    "# Gene mutations\n",
    "mutation_cols = [col for col in df.columns if col.endswith(\"_mut\")]\n",
    "mutations_df = df[mutation_cols].copy()\n",
    "\n",
    "print(\"Mutation data shape:\", mutations_df.shape)\n",
    "\n",
    "# Gene expressions\n",
    "expression_cols = [col for col in df.columns if col not in clinical_cols and col not in mutation_cols]\n",
    "expression_df = df[expression_cols].copy()\n",
    "\n",
    "print(\"Gene expression data shape:\", expression_df.shape)\n",
    "\n",
    "# Double check that the splits are correct\n",
    "print(\"Number of clinical + expression + mutation columns =\", \n",
    "      len(clinical_df.columns) + len(expression_df.columns) + len(mutations_df.columns))\n",
    "print(\"Total columns in original df =\", len(df.columns))"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Clinical attributes shape: (1904, 31)\n",
      "Mutation data shape: (1904, 173)\n",
      "Gene expression data shape: (1904, 489)\n",
      "Number of clinical + expression + mutation columns = 693\n",
      "Total columns in original df = 693\n"
     ]
    }
   ],
   "execution_count": 30
  },
  {
